build ToyDialectIncGen: phony toy/ToyDialectIncGen

build ToyOpsIncGen: phony toy/ToyOpsIncGen

build install-toy-dialect: phony toy/install-toy-dialect

build install-toy-dialect-stripped: phony toy/install-toy-dialect-stripped

build install-toy-passes: phony passes/install-toy-passes

build install-toy-passes-stripped: phony passes/install-toy-passes-stripped

build libtoy-dialect.a: phony toy/libtoy-dialect.a

build libtoy-passes.so: phony passes/libtoy-passes.so

build obj.toy-dialect: phony toy/obj.toy-dialect

build toy-dialect: phony toy/libtoy-dialect.a

build toy-opt: phony tools/toy-opt

build toy-passes: phony passes/libtoy-passes.so

