#############################################
# Folder: /workspace/build

build all: phony mlir_tutorial toy/all passes/all tools/all

# =============================================================================

#############################################
# Folder: /workspace/build/passes

build passes/all: phony passes/libtoy-passes.so

# =============================================================================

#############################################
# Folder: /workspace/build/tools

build tools/all: phony tools/toy-opt

# =============================================================================

#############################################
# Folder: /workspace/build/toy

build toy/all: phony toy/libtoy-dialect.a

